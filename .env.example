# Copy to .env.local (gitignored) and fill in. .env.local overrides .env.
# .env itself is committed and should not contain secrets.

# Comma- or space-separated list of hostnames (or full URLs — protocol/path
# stripped) for which Primo AdBlock is disabled by default on first install.
# Subdomains are matched automatically. Read at build time by
# tools/primo-prebuild.mjs and baked into
PRIMO_DEFAULT_TRUSTED_SITES=
